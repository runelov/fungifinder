// js/github-store.js
// Enkel "GitHub som database"-lagring for FungiFinder.
// Lagrer alle personlige data (funn, hogst-merker, egne steder) som én JSON-fil
// i et GitHub-repo, via GitHub sitt Contents API. Krever en fine-grained
// personal access token med "Contents: Read and write" på det aktuelle repoet.
//
// Sikkerhetsmerknad: tokenet lagres i nettleserens localStorage på enheten din.
// Bruk et fine-grained token begrenset til KUN dette ene repoet, og helst et
// privat repo for selve dataene (index.html/appkoden kan gjerne være i et
// offentlig repo for GitHub Pages, men datafilen bør ligge i et privat repo
// eller en privat branch hvis du er bekymret for at andre skal se funnstedene dine).

const GH_CONFIG_KEY = 'fungifinder-gh-config';
const LOCAL_FALLBACK_KEY = 'fungifinder-local-data';

function getConfig(){
  try {
    const raw = localStorage.getItem(GH_CONFIG_KEY);
    return raw ? JSON.parse(raw) : null;
  } catch(e){ return null; }
}

function setConfig(cfg){
  localStorage.setItem(GH_CONFIG_KEY, JSON.stringify(cfg));
}

function clearConfig(){
  localStorage.removeItem(GH_CONFIG_KEY);
}

function isConfigured(){
  const c = getConfig();
  return !!(c && c.owner && c.repo && c.path && c.token);
}

// Unicode-sikker base64-koding/dekoding (GitHub API krever base64 av UTF-8-bytes)
function utf8ToBase64(str){
  return btoa(unescape(encodeURIComponent(str)));
}
function base64ToUtf8(b64){
  return decodeURIComponent(escape(atob(b64)));
}

async function ghRequest(cfg, method, body){
  const url = `https://api.github.com/repos/${cfg.owner}/${cfg.repo}/contents/${encodeURIComponent(cfg.path)}${cfg.branch ? '?ref=' + encodeURIComponent(cfg.branch) : ''}`;
  const headers = {
    'Authorization': `Bearer ${cfg.token}`,
    'Accept': 'application/vnd.github+json',
    'X-GitHub-Api-Version': '2022-11-28'
  };
  if (method === 'PUT') headers['Content-Type'] = 'application/json';
  const res = await fetch(url, { method: method || 'GET', headers, body: body ? JSON.stringify(body) : undefined });
  return res;
}

// Henter data-objektet fra GitHub. Returnerer null hvis filen ikke finnes ennå
// (helt normalt ved første gangs bruk — den opprettes ved første lagring).
async function load(){
  const cfg = getConfig();
  if (!cfg) return null;
  const res = await ghRequest(cfg, 'GET');
  if (res.status === 404) return { data: null, sha: null };
  if (!res.ok) throw new Error(`GitHub API-feil ved henting (${res.status}): ${await res.text()}`);
  const json = await res.json();
  const content = base64ToUtf8(json.content.replace(/\n/g, ''));
  return { data: JSON.parse(content), sha: json.sha };
}

// Lagrer data-objektet til GitHub. Trenger sha fra forrige load() for å oppdatere
// eksisterende fil (unngår at to enheter overskriver hverandre uten varsel).
async function save(dataObj, previousSha){
  const cfg = getConfig();
  if (!cfg) throw new Error('GitHub-synk er ikke konfigurert.');
  const body = {
    message: `FungiFinder: oppdater data (${new Date().toISOString()})`,
    content: utf8ToBase64(JSON.stringify(dataObj, null, 2)),
    branch: cfg.branch || undefined
  };
  if (previousSha) body.sha = previousSha;
  const res = await ghRequest(cfg, 'PUT', body);
  if (!res.ok) throw new Error(`GitHub API-feil ved lagring (${res.status}): ${await res.text()}`);
  const json = await res.json();
  return json.content.sha;
}

// Lokal fallback (localStorage) — brukes automatisk hvis GitHub-synk ikke er satt opp,
// slik at appen fungerer med det samme uten noe oppsett.
function loadLocal(){
  try {
    const raw = localStorage.getItem(LOCAL_FALLBACK_KEY);
    return raw ? JSON.parse(raw) : null;
  } catch(e){ return null; }
}
function saveLocal(dataObj){
  localStorage.setItem(LOCAL_FALLBACK_KEY, JSON.stringify(dataObj));
}

window.FungiStore = { getConfig, setConfig, clearConfig, isConfigured, load, save, loadLocal, saveLocal };
